{
  "name": "otacon",
  "version": "0.1.6",
  "description": "Plan review surface for coding agents — mission support over codec.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeroliu/otacon.git"
  },
  "homepage": "https://github.com/zeroliu/otacon#readme",
  "bugs": {
    "url": "https://github.com/zeroliu/otacon/issues"
  },
  "bin": {
    "otacon": "dist/cli/main.js",
    "otacond": "dist/daemon/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun run scripts/gen-skill-asset.ts && vite build src/ui && chmod +x dist/cli/main.js dist/daemon/main.js",
    "typecheck": "tsc --noEmit && tsc -p src/ui && tsc -p src/ui/tsconfig.test.json",
    "test": "bun test",
    "dev:daemon": "bun run src/daemon/main.ts",
    "dev:ui": "vite src/ui",
    "e2e": "bash test/e2e-daemon.sh",
    "e2e:cli": "bash test/e2e-cli.sh",
    "e2e:revise": "bash test/e2e-revise.sh",
    "e2e:grill": "bash test/e2e-grill.sh",
    "e2e:install": "bash test/e2e-install.sh",
    "e2e:ui": "bun run build && playwright test",
    "smoke": "bash test/smoke.sh",
    "accept": "bash test/acceptance.sh",
    "verify:branch": "bash test/verify-branch.sh",
    "gen:version": "bun run scripts/gen-version.ts",
    "gen:skill": "bun run scripts/gen-skill-asset.ts",
    "version": "bun run gen:version && git add src/shared/version.ts",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "happy-dom": "^20.10.3",
    "hono": "^4",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dompurify": "^3.4.10",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.21.0",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5",
    "vite": "^8.0.16"
  }
}
