    "smoke": "bash test/smoke.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "hono": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24",
    "typescript": "^5"
  }
}
