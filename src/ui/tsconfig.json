{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["."],
  "//exclude": "Test files (.test.ts AND .test.tsx) are bun:test files needing bun's types; they compile under src/ui/tsconfig.test.json, never this DOM-app program (which carries no bun types).",
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
